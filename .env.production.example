# Production Environment Configuration
# IMPORTANTE: Copiar este arquivo e ajustar valores antes de fazer deploy

APP_NAME=YourApp
APP_ENV=production
APP_KEY=                        # GERAR COM: php artisan key:generate
APP_DEBUG=false                 # NUNCA true em produção
APP_URL=https://yourdomain.com
APP_DOMAIN=yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily                # Usar 'daily' em produção
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                # 'error' ou 'warning' em produção

# Database Configuration
DB_CONNECTION=pgsql
DB_HOST=your-db-host
DB_PORT=5432
DB_DATABASE=your_database
DB_USERNAME=your_user
DB_PASSWORD=your_secure_password

# Session Configuration (SEGURANÇA CRÍTICA)
# ⚠️ ATENÇÃO: Estas configurações impactam diretamente a segurança multi-tenant
SESSION_DRIVER=redis           # Usar Redis ou database em produção
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# SESSION_DOMAIN: DEVE ser null em produção para isolamento entre tenants
# ❌ NUNCA usar SESSION_DOMAIN=.yourdomain.com em sistemas multi-tenant
# ✅ Deixar vazio para cookies isolados por domínio exato
#
# Comportamento:
# - null: Cookie de tenant1.yourdomain.com NÃO acessível em tenant2.yourdomain.com
# - .yourdomain.com: Cookie compartilhado entre TODOS os subdomínios (INSEGURO)
#
# Impersonation funciona SEM compartilhar cookies (via token)
SESSION_DOMAIN=

# SESSION_SAME_SITE: Proteção contra CSRF
# Opções:
# - strict: Máxima segurança, cookies apenas em same-site (pode quebrar alguns flows)
# - lax: Seguro, permite GET redirects (RECOMENDADO para impersonation)
# - none: INSEGURO, permite cross-site (requer HTTPS + Secure flag)
#
# ✅ RECOMENDADO: lax (funciona com impersonation e protege contra CSRF)
SESSION_SAME_SITE=lax

SESSION_PATH=/
SESSION_SECURE_COOKIE=true     # OBRIGATÓRIO em produção com HTTPS

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3             # Usar S3 em produção multi-tenant
QUEUE_CONNECTION=redis         # Usar Redis ou SQS em produção

CACHE_STORE=redis              # Redis recomendado para produção
CACHE_PREFIX=

# Redis Configuration (Multi-Database Strategy)
# IMPORTANTE: Usa múltiplas databases Redis para isolamento:
# - DB 0 (default): Sessions + Direct Redis calls (tenant-prefixed via RedisTenancyBootstrapper)
# - DB 1 (cache): Cache (tenant-tagged via CacheTenancyBootstrapper)
# - DB 2 (queue): Queue jobs (NO tenant prefix - previne conflitos)
#
# Ver: config/database.php:145-194
# Ver: config/tenancy.php:174-180 (prefixed_connections)
# Ver: config/tenancy.php:103-106 (scope_sessions)
REDIS_CLIENT=phpredis
REDIS_HOST=your-redis-host
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379
REDIS_DB=0              # Default connection (sessions + direct Redis::get/set calls)
REDIS_CACHE_DB=1        # Cache connection
REDIS_QUEUE_DB=2        # Queue connection (MUST be separate - see config/tenancy.php:177)

# Email Configuration
MAIL_MAILER=smtp               # Usar serviço real (SES, Mailgun, Postmark)
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=your_email_user
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration (para S3)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your_bucket_name
AWS_USE_PATH_STYLE_ENDPOINT=false

# Stripe (Laravel Cashier)
STRIPE_KEY=pk_live_xxxx                    # CHAVES LIVE, não test
STRIPE_SECRET=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Telescope - DESABILITAR EM PRODUÇÃO ou PROTEGER COM AUTENTICAÇÃO
TELESCOPE_ENABLED=false                     # ❌ NUNCA true em produção pública
TELESCOPE_MCP_ENABLED=false

# Security Headers (via AddSecurityHeaders middleware)
# Já configurado em app/Http/Middleware/AddSecurityHeaders.php

# CORS Configuration (se necessário)
# SANCTUM_STATEFUL_DOMAINS=yourdomain.com,*.yourdomain.com

# Rate Limiting (já configurado em bootstrap/app.php)
# Ajustar limites conforme necessidade em produção

# ========================================
# CHECKLIST DE SEGURANÇA PRODUÇÃO
# ========================================
#
# [ ] APP_DEBUG=false
# [ ] APP_ENV=production
# [ ] SESSION_DOMAIN=null (vazio)
# [ ] SESSION_SAME_SITE=lax ou strict
# [ ] SESSION_SECURE_COOKIE=true
# [ ] LOG_LEVEL=error ou warning
# [ ] TELESCOPE_ENABLED=false
# [ ] Chaves Stripe LIVE configuradas
# [ ] Banco de dados com backup automático
# [ ] Redis com persistência configurada
# [ ] S3 para arquivos com lifecycle policies
# [ ] Rate limiting ajustado para carga esperada
# [ ] Monitoring configurado (Sentry, LogRocket, etc)
# [ ] SSL/TLS certificados válidos
# [ ] Firewall configurado (apenas portas 80, 443)
# [ ] Backups automáticos configurados
# [ ] Secrets em vault (AWS Secrets Manager, etc)
#
# ========================================
# MULTI-TENANT SECURITY
# ========================================
#
# 1. Session Isolation:
#    ✅ SESSION_DOMAIN=null (isolamento por domínio)
#    ✅ Cada tenant tem sua própria sessão
#    ✅ Impersonation via token (não compartilha cookies)
#
# 2. Database Isolation:
#    ✅ tenant_id em todos os models com BelongsToTenant trait
#    ✅ Route model binding verifica tenant (bootstrap/app.php)
#    ✅ Middleware VerifyTenantAccess em todas as rotas tenant
#
# 3. Storage Isolation:
#    ✅ Filesystem disk usa tenant_id como prefixo
#    ✅ S3 paths: tenants/{tenant_id}/...
#
# 4. CSRF Protection:
#    ✅ SESSION_SAME_SITE=lax
#    ✅ CSRF tokens em todos os forms
#    ✅ SameSite cookies previnem cross-site attacks
#
# 5. Rate Limiting:
#    ✅ Por tenant (previne um tenant afetar outros)
#    ✅ Limites por usuário e por tenant
#    ✅ Upload rate limiting separado
#
# ========================================
# IMPERSONATION SECURITY
# ========================================
#
# O sistema de impersonation é seguro porque:
#
# 1. Token-based: Não depende de cookies compartilhados
# 2. Single-use: Token consumido após primeiro uso
# 3. Time-limited: Tokens expiram em 5 minutos
# 4. Audit trail: Registra quem impersonou quem
# 5. Domain-isolated: Cada tenant tem sua própria sessão
#
# Fluxo seguro:
# admin.yourdomain.com → cria token → tenant1.yourdomain.com/impersonate/{token}
# → token validado → NOVA sessão criada em tenant1.yourdomain.com
# → cookies NÃO compartilhados entre admin e tenant1
#
