APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://app.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_LOCALES=en,pt_BR,es
APP_TIMEZONE=UTC

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration (Mailpit for development)
# Mailpit Web UI: http://localhost:8025
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Mailpit ports (Docker)
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

TELESCOPE_MCP_ENABLED=true
TELESCOPE_MCP_PATH=telescope-mcp

# CORS Configuration
# Comma-separated list of allowed origins (leave empty to use patterns only)
# Example: https://app.setor3.app,https://admin.setor3.app
CORS_ALLOWED_ORIGINS=

# App domain for CORS pattern matching (used in config/cors.php)
# In production: setor3.app
# In development: myapp.test or localhost
APP_DOMAIN=myapp.test

# Stripe Configuration
STRIPE_KEY=pk_test_xxxxx
STRIPE_SECRET=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price IDs and Meter IDs are stored in the database.
# Use `sail artisan stripe:sync --addons` to create products/prices in Stripe
# and automatically populate the IDs in the addons table.

# Payment Gateway Configuration
# Note: Gateway credentials, sandbox mode, and enabled status are managed
# in the database via PaymentSetting model (Admin > Payment Settings).
# These ENV vars are for defaults and URL overrides.
PAYMENT_DRIVER=stripe
PAYMENT_CURRENCY=BRL
PAYMENT_CURRENCY_LOCALE=pt_BR

# API URL Overrides (optional - defaults are correct)
# Only set these if you need to use a different API endpoint
# ASAAS_API_URL=https://api.asaas.com/v3
# ASAAS_SANDBOX_URL=https://api-sandbox.asaas.com/v3
# PAGSEGURO_API_URL=https://api.pagseguro.com
# PAGSEGURO_SANDBOX_URL=https://sandbox.api.pagseguro.com
# MERCADOPAGO_API_URL=https://api.mercadopago.com
